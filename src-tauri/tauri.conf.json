{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "exp1",
  "version": "0.1.0",
  "identifier": "com.ruinb0w.exp1",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "exp1",
        "width": 800,
        "height": 600,
        "decorations": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "targets": ["msi", "nsis"]
  }
}
